def setup_logging(level: str = "WARN") -> None:
    m = {"debug": logging.DEBUG, "info": logging.INFO,
         "warn": logging.WARNING, "error": logging.ERROR}
    fh = logging.FileHandler(LOG_FILE)
    fh.setFormatter(logging.Formatter("%(asctime)s [%(levelname)s] %(message)s"))
    logger.addHandler(fh)
    logger.setLevel(m.get(level.lower(), logging.WARNING))

# ── Data Structures ───────────────────────────────────────────────────

@dataclass
class MenuEntry:
    label: str = ""
    icon: str = ""
    command: list[str] | None = None
    children: list[MenuEntry] | None = None
    disabled: bool = False
    separator: bool = False
    heading: bool = False
    shell: bool = False
    confirm: bool = False
    keep_open: bool = False
    dynamic: str = ""

    @property
    def is_leaf(self) -> bool:
        return bool(self.command) or self.separator or self.heading

    @property
    def has_children(self) -> bool:
        return bool(self.children) and not self.is_leaf

    @classmethod
    def from_toml(cls, d: dict) -> "MenuEntry":
        kids = [cls.from_toml(c) for c in d.get("children", [])] if d.get("children") else None
        return cls(label=d.get("label", ""), icon=d.get("icon", ""),
                   command=d.get("command"), children=kids or None,
                   disabled=d.get("disabled", False), separator=d.get("separator", False),
                   heading=d.get("heading", False), shell=d.get("shell", False),
                   confirm=d.get("confirm", False), keep_open=d.get("keep_open", False),
                   dynamic=d.get("dynamic", ""))

