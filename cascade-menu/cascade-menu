    icon_spacing: str = " "
    @classmethod
    def from_toml(cls, d: dict) -> "Theme":
        return cls(**{k: v for k, v in d.items() if k in cls.__dataclass_fields__})

@dataclass
class Config:
    theme: str = "gruvbox-dark"
    show_footer: bool = True
    nerd_font_icons: bool = True
    wrap_navigation: bool = True
    max_menu_height: int = 50
    column_min_width: int = 28
    column_max_width: int = 48
    opacity: float = 1.0
    border_style: str = "sharp"
    close_on_escape: bool = True
    restore_parent_selection: bool = True
    close_on_focus_lost: bool = True
    anchor: str = "top-left"
    offset_x: int = 8
    offset_y: int = 0
    bar_height: int = 20
    column_gap: int = 2
    log_level: str = "warn"
    editor_cmd: list[str] = field(default_factory=lambda: _detect_editor())
    bind_close: list[str] = field(default_factory=lambda: ["Escape", "q"])
    bind_up: list[str] = field(default_factory=lambda: ["k", "Up"])
    bind_down: list[str] = field(default_factory=lambda: ["j", "Down"])
    bind_back: list[str] = field(default_factory=lambda: ["h", "Left"])
    bind_forward: list[str] = field(default_factory=lambda: ["l", "Right"])
    bind_execute: list[str] = field(default_factory=lambda: ["Return", "KP_Enter"])
    bind_first: list[str] = field(default_factory=lambda: ["g"])
    bind_last: list[str] = field(default_factory=lambda: ["G"])
    bind_search: list[str] = field(default_factory=lambda: ["slash"])
    @classmethod
    def from_toml(cls, d: dict) -> "Config":
        cfg = cls()
        for section in ("appearance", "behavior", "position", "logging", "keybindings"):
            if section in d:
                for k, v in d[section].items():
                    if hasattr(cfg, k):
                        setattr(cfg, k, v)
        return cfg

def _detect_editor() -> list[str]:
    env = os.environ.get("VISUAL") or os.environ.get("EDITOR") or ""
    if env:
        return shlex.split(env)
    for ed in ["emacs", "nvim", "vim", "nano"]:
        if shutil.which(ed):
            return [ed]
    return ["nvim"]

# ── Loaders ───────────────────────────────────────────────────────────

def load_toml(path: Path) -> dict:
    with open(path, "rb") as f:
        return tomllib.load(f)

LOCAL_CONFIG = CONFIG_DIR / "config.local"

def load_config() -> Config:
    try:
        cfg = Config.from_toml(load_toml(CONFIG_FILE))
        # Apply local overrides (e.g. theme from i3 theme switcher)
        if LOCAL_CONFIG.exists():
            local = load_toml(LOCAL_CONFIG)
            for section in local:
                for k, v in local[section].items():
                    if hasattr(cfg, k):
                        setattr(cfg, k, v)
        return cfg
    except Exception as e:
        logger.warning("config load failed: %s", e)
        return Config()

def load_theme(name: str) -> Theme:
    path = THEMES_DIR / f"{name}.toml"
    if not path.exists():
        path = THEMES_DIR / f"{name.lower().replace(' ', '-')}.toml"
    try:
        return Theme.from_toml(load_toml(path))
    except Exception as e:
        logger.warning("theme '%s' not found: %s", name, e)
        fallback = THEMES_DIR / "gruvbox-dark.toml"
        if fallback.exists():
            return load_theme("gruvbox-dark")
        return Theme()

DESKTOP_DIRS = [
    Path("/usr/share/applications"),
    Path.home() / ".local/share/applications",
]

def _scan_desktop(dynamic_type: str) -> list[MenuEntry]:
    """Scan .desktop files and return matching MenuEntry list."""
    seen: set[str] = set()
    entries: list[MenuEntry] = []
    cat_map = {
        "AudioVideo": "audio", "Audio": "audio", "Video": "video",
        "Development": "dev", "Education": "edu", "Game": "game",
        "Graphics": "graphics", "Network": "network",
        "Office": "office", "Settings": "settings",
        "System": "system", "Utility": "utility",
        "WebBrowser": "browsers",
    }

    for d in DESKTOP_DIRS:
        if not d.exists():
            continue
        for f in sorted(d.glob("*.desktop")):
            try:
                info = GioUnix.DesktopAppInfo.new_from_filename(str(f))
                if not info or not info.should_show():
                    continue
                name = info.get_display_name()
                if not name or name in seen:
                    continue
                seen.add(name)
                exec_str = info.get_commandline()
                if not exec_str:
                    continue
                cats = (info.get_categories() or "").split(";")
                if dynamic_type == "apps":
                    entries.append(MenuEntry(label=name, command=_split_exec(exec_str)))
                else:
                    # Match if any category maps to this dynamic_type
                    mapped = {cat_map.get(c) for c in cats if c in cat_map}
                    if dynamic_type in mapped:
                        entries.append(MenuEntry(label=name, command=_split_exec(exec_str)))
            except Exception:
                continue

    entries.sort(key=lambda e: e.label.lower())
    return entries

def _split_exec(exec_str: str) -> list[str]:
    """Parse a .desktop Exec line into a command list, stripping field codes."""
    parts = []
    buf = ""
    in_quote = None
    i = 0
    while i < len(exec_str):
        ch = exec_str[i]
        if in_quote:
            if ch == in_quote:
                in_quote = None
            else:
                buf += ch
        elif ch in ('"', "'"):
            in_quote = ch
        elif ch == " ":
            if buf:
                parts.append(buf)
                buf = ""
        elif ch == "%":
            i += 1  # skip field-code letter (%f, %F, %u, %U, etc.)
        else:
            buf += ch
        i += 1
    if buf:
        parts.append(buf)
    filtered = [p for p in parts if p not in ("", "/usr/bin/sh", "-c")]
    return filtered or parts

def _expand_dynamic(items: list[MenuEntry]) -> list[MenuEntry]:
    """Replace items with dynamic=True with generated children."""
    result = []
    for item in items:
        if item.dynamic:
            result.append(MenuEntry(
                label=item.label, icon=item.icon,
                children=_scan_desktop(item.dynamic)))
        elif item.children:
            item.children = _expand_dynamic(item.children)
            result.append(item)
        else:
            result.append(item)
    return result

def load_menu() -> list[MenuEntry]:
    try:
        raw = load_toml(MENU_FILE).get("menu", [])
        items = [MenuEntry.from_toml(item) for item in raw]
        items = _expand_dynamic(items)
        logger.info("loaded %d root items", len(items))
        return items
    except Exception as e:
        logger.error("menu load failed: %s", e)
        return []

