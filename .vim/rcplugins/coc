" Jump to next / previous error
nmap <silent> ]r <Plug>(coc-diagnostic-next-error)
nmap <silent> [r <Plug>(coc-diagnostic-prev-error)

" show documentation (K key)
function! s:show_documentation()
  if (index(['vim','help'], &filetype) >= 0)
    execute 'h '.expand('<cword>')
  else
    call CocAction('doHover')
  endif
endfunction
nnoremap <silent> K :call <SID>show_documentation()<CR>

" show error, otherwise documentation, on hold
function! ShowDocIfNoDiagnostic(timer_id)
  " if (coc#util#has_float() == 0)
  silent call CocActionAsync('doHover')
  " endif
endfunction
function! s:show_hover_doc()
  call timer_start(200, 'ShowDocIfNoDiagnostic')
endfunction
nnoremap <leader>k :call <SID>show_hover_doc()<cr>

" Format mappings
nnoremap <leader>fm :call CocAction('format')<CR>
xnoremap <leader>fm <Plug>(coc-format-selected)

" Toggle inlay hints
nnoremap <leader>h :CocCommand document.toggleInlayHint<CR>

" Format command
command! -nargs=0 Fm :call CocActionAsync('format')

" Highlight on cursor hold
autocmd CursorHold * silent call CocActionAsync('highlight')

