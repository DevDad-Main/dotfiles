" JavaScript - JS syntax and indent settings, along with JSX support

Plug 'pangloss/vim-javascript'
Plug 'mxw/vim-jsx'
let g:jsx_ext_required = 1

Plug 'chemzqm/vim-jsx-improve', { 'for': 'javascript.jsx' }

autocmd BufEnter *.es6 setf javascript

" JS/TS indentation - matching your backup config
autocmd FileType javascript,typescript,jsx,tsx setlocal softtabstop=2 shiftwidth=2 autoindent smartindent
autocmd FileType javascript,typescript,jsx,tsx setlocal indentkeys+=<Space>,!^F,o,O,e

command! EslintDStop call system("./node_modules/.bin/eslint_d stop")

" vim:ft=vim
