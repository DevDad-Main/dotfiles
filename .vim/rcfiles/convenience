" Convience - configs & mappings to smooth out rough edges and make vim feel like home

" Fix leader key delay
set timeoutlen=300
set ttimeoutlen=50

" Block cursor in Normal mode, line cursor in Insert mode
let &t_SI = "\e[6 q"
let &t_EI = "\e[2 q"

" Coc responsiveness
set updatetime=100

" System clipboard
vnoremap <leader>y "+y
nnoremap <leader>y "+y
vnoremap <C-y> "+y

" Move between wrapped lines, rather than jumping over wrapped segments
nmap j jzzzv
nmap k kzzzv

" Use C-Space to Esc out of any mode (normal/visual only)
nnoremap <C-Space> <Esc>:noh<cr>
vnoremap <C-Space> <Esc>gV
onoremap <C-Space> <Esc>
cnoremap <C-Space> <C-c>
" Terminal sees <C-@> as <C-space>
nnoremap <C-@> <Esc>:noh<cr>
vnoremap <C-@> <Esc>gV
onoremap <C-@> <Esc>
cnoremap <C-@> <C-c>

" Escape Insert Mode Quicker
inoremap jj <Esc>
inoremap jk <Esc>

" Better navigation - center screen on search
nmap n nzzzv
nmap N Nzzzv
" Better C-d/C-u - center screen
nnoremap <C-d> <C-d>zz
nnoremap <C-u> <C-u>zz

" Tab navigation
nnoremap <C-t> <Cmd>tabnew<CR>
nnoremap <C-x> <Cmd>tabclose<CR>
for i in range(1, 8)
  execute 'nnoremap <Leader>' . i . ' :tabnext ' . i . '<CR>'
endfor

" Buffer management
nnoremap <leader>d :bd<CR>
nnoremap <leader>w :update<CR>
nnoremap <leader>q :quit<CR>
nnoremap <leader>Q :wqa<CR>
nnoremap <C-q> :copen<CR>

" Source and edit config
nnoremap <leader>v :edit $MYVIMRC<CR>
nnoremap <leader>o :source ~/.vimrc<CR>
nnoremap <leader>O :source ~/.vimrc<CR>

" Substitute (same as your C-s)
nnoremap <C-s> :%s/
vnoremap <C-s> :s/

" Format - CoC prettier
nnoremap <leader>m :call CocAction('format')<CR>
vnoremap <leader>m :call CocAction('formatSelected')<CR>

" Spell correction - only if spell is enabled
nnoremap <leader>c :<C-u>let &spelllang = &spelllang \| normal! 1z=<CR>

" Alternate file
nnoremap <leader>a :edit #<CR>

" LazyGit (requires lazygit installed)
nnoremap <leader>l :!lazygit<CR>

" Select all
nnoremap <leader>A ggVG

" Window navigation
nnoremap <C-h> <C-w>h
nnoremap <C-j> <C-w>j
nnoremap <C-k> <C-w>k
nnoremap <C-l> <C-w>l

" Split management
nnoremap <leader>wv :vsplit<CR>
nnoremap <leader>ws :split<CR>

" Resize splits (Alt + hjkl)
nnoremap <M-h> :vertical resize -5<CR>
nnoremap <M-l> :vertical resize +5<CR>
nnoremap <M-j> :resize +2<CR>
nnoremap <M-k> :resize -2<CR>

" Toggle Netrw
nnoremap <leader>e :Lexplore<CR>
nnoremap <leader>f :Files<CR>

" Quickly enter new line in insert mode
inoremap <C-;> <C-o>o

" Insert mode navigation
inoremap <C-h> <Left>
inoremap <C-l> <Right>
inoremap <C-x> <BS>

" Remove Search Highlighting, Dismiss Popups
nnoremap <esc> :noh<CR>

nnoremap <leader>cc :ClearEmAll<cr>

command! ClearEmAll call s:ClearEmAll()

function! s:ClearEmAll()
  nohlsearch
  cclose
  pclose
  lclose
  " call coc#util#float_hide()
  call popup_clear()
endfunction

" Quick sourcing of the current file, allowing for quick vimrc testing
nnoremap <leader>sop :source %<cr>

nnoremap <leader>df :Files ~/code/dotfiles<cr>
nnoremap <leader>; :
nmap <leader>bi :PlugInstall<cr>

" Q for Ex mode is useless. This will run the macro in q register
nnoremap Q @q

" Swap 0 and ^. I tend to want to jump to the first non-whitespace character
" so make that the easier one to do.
nnoremap 0 ^
nnoremap ^ 0

augroup vimrcEx
  autocmd!
  " When editing a file, always jump to the last known cursor position.
  " Don't do it for commit messages, when the position is invalid, or when
  " inside an event handler (happens when dropping a file on gvim).
  autocmd BufReadPost *
    \ if &ft != 'gitcommit' && line("'\"") > 0 && line("'\"") <= line("$") |
    \   exe "normal g`\"" |
    \ endif
augroup END

" Switch between the last two files
nnoremap <leader><leader> <c-^>

nnoremap <leader>rf :!clear && node %<CR>

