[
  {
    "context": "(Editor && mode == full)",
    "bindings": {
      "ctrl-h": null
    }
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "space f": "file_finder::Toggle",
      "space p": "command_palette::Toggle",
      "space n": "workspace::NewFile",
      "space a": "editor::SelectAll",
      "ctrl-s": "workspace::Save",
      "space w": "workspace::Save",
      "space g": "workspace::NewSearch",
      "space z": "editor::FindAllReferences",
      "ctrl-t": "terminal_panel::ToggleFocus",
      "space l": "terminal_panel::ToggleFocus",
      "space h": "editor::ToggleInlayHints",
      "space c d": "editor::GoToDefinition",
      "space c i": "editor::GoToImplementation",
      "space c r": "editor::FindAllReferences",
      "space c a": "editor::ToggleCodeActions",
      "space c h": "editor::Hover",
      "space c n": "editor::Rename",
      "space c l": "diagnostics::Deploy",
      "space c shift-d": "diagnostics::Deploy",
      "space s": "workspace::NewSearch",
      "space s i": "editor::FindAllReferences",
      "space s o": "file_finder::Toggle",
      "space s r": "editor::FindAllReferences",
      "space s d": "editor::GoToDefinition",
      "space s shift-d": "diagnostics::Deploy",
      "space s t": "editor::GoToTypeDefinition",
      "space o": "outline::Toggle",
      "space w s": "pane::SplitDown",
      "space w v": "pane::SplitRight",
      "space e": "project_panel::ToggleFocus",
      "space d": "pane::CloseActiveItem",
      "space b": "tab_switcher::ToggleAll",
      "space r": "buffer_search::DeployReplace",
      "ctrl-/": "editor::ToggleComments",
      "space k": "command_palette::Toggle",
      "space m": "editor::Format",
      "ctrl-d": ["editor::MovePageDown", { "center_cursor": true }],
      "ctrl-u": ["editor::MovePageUp", { "center_cursor": true }],
      "space q": "workspace::CloseWindow",
      "space shift-q": "workspace::CloseWindow",
      "space v": "workspace::OpenSettings"
    }
  },
  {
    "context": "Workspace && !Editor && !Terminal",
    "bindings": {
      "q": "workspace::ToggleLeftDock",
      "space e": "workspace::ToggleLeftDock"
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "ctrl-/": "editor::ToggleComments",
      "p": "editor::Paste"
    }
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-s": "workspace::Save",
      "ctrl-x": "editor::Backspace",
      "j j": "vim::SwitchToNormalMode"
    }
  },
  {
    "context": "Terminal",
    "use_key_equivalents": true,
    "bindings": {
      "ctrl-t": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Editor && vim_mode == insert && showing_completions",
    "bindings": {
      "ctrl-j": "editor::ContextMenuNext",
      "ctrl-k": "editor::ContextMenuPrevious"
    }
  },
  {
    "context": "Editor && (showing_code_actions || showing_completions)",
    "bindings": {
      "ctrl-k": "editor::ContextMenuPrevious",
      "ctrl-j": "editor::ContextMenuNext"
    }
  },
  {
    "context": "picker || menu || tab_switcher",
    "bindings": {
      "ctrl-j": "menu::SelectNext",
      "ctrl-k": "menu::SelectPrevious"
    }
  },
  {
    "context": "Workspace && !menu",
    "bindings": {
      "space b": "tab_switcher::ToggleAll",
      "ctrl-x": "tab_switcher::CloseSelectedItem"
    }
  },
  {
    "context": "Editor && vim_mode == insert && !menu && !showing_completions && !showing_code_actions",
    "bindings": {
      "ctrl-h": "editor::MoveLeft",
      "ctrl-l": "editor::MoveRight",
      "ctrl-j": "editor::MoveDown",
      "ctrl-k": "editor::MoveUp"
    }
  },
  {
    "context": "Editor && vim_mode == insert && !menu",
    "bindings": {
      "ctrl-e": "vim::EndOfLine",
      "ctrl-a": "vim::StartOfLine"
    }
  },
  {
    "context": "Editor && vim_mode == normal || vim_mode == visual && !menu",
    "bindings": {
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp"
    }
  },
  {
    "context": "(GitPanel || ChangesList || Terminal || Workspace || Editor) && !menu && !picker && !tab_switcher && vim_mode == normal",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-j": "workspace::ActivatePaneDown",
      "ctrl-k": "workspace::ActivatePaneUp",
      "ctrl-l": "workspace::ActivatePaneRight"
    }
  },
  {
    "context": "Editor && vim_mode == normal && !menu",
    "bindings": {
      "alt-h": ["workspace::ActivatePaneLeft", { "focus": false }],
      "alt-l": ["workspace::ActivatePaneRight", { "focus": false }]
    }
  },
  {
    "context": "GitPanel && ChangesList",
    "use_key_equivalents": true,
    "bindings": {
      "k": "menu::SelectPrevious",
      "j": "menu::SelectNext",
      "g g": "menu::SelectFirst",
      "shift-g": "menu::SelectLast",
      "d": "menu::Confirm",
      "i": "git_panel::FocusEditor",
      "s": "git::ToggleStaged",
      "shift-s": "git::StageAll",
      "g x": "git::StageRange",
      "shift-u": "git::UnstageAll"
    }
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "S": ["vim::PushAddSurrounds", {}]
    }
  }
]
